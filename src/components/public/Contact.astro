---
// Bagian_Kontak + Footer — komponen statis (Req 6.1–6.4), gaya neobrutalism.
//
// Bagian_Kontak bersifat sepenuhnya statis: tidak ada pengambilan data runtime.
// Alamat email Pemilik dan tautan profesional diinjeksi saat build dari
// `siteConfig`.
//
//   - Menampilkan Tautan_Mailto yang `href`-nya tepat sama dengan
//     `"mailto:" + email` melalui util murni `buildMailtoLink` (Req 6.1, 6.2).
//   - Menampilkan tautan media profesional bila dikonfigurasi (Req 6.3);
//     setiap tautan dibuka pada tab baru dengan aman menggunakan
//     `target="_blank"` dan `rel="noopener noreferrer"` (Req 6.4).
//   - Footer "© 2025 - <NAMA>" beserta tautan sosial.
//
// Desain neobrutalism: judul "KONTAK" font-display kapital, kartu berborder
// tebal (border-4 border-light-text dark:border-dark-text) dengan hard offset
// shadow (shadow-brutal), aksen oranye (token primary), dan hover taktil.
// Section dibungkus `<section id="contact">` agar selaras dengan NAV_LINKS.

import { siteConfig } from '../../config/site';

export interface Props {
  /** ID anchor section agar dapat dituju Menu_Navigasi (default: "contact"). */
  sectionId?: string;
}

const { sectionId = 'contact' } = Astro.props;

const socialLinks = siteConfig.socialLinks ?? [];
const ownerName = siteConfig.ownerName;
const year = new Date().getFullYear();
---

<section
  id={sectionId}
  aria-labelledby={`${sectionId}-heading`}
  class="mx-auto w-full max-w-content px-4 py-12 sm:px-6 lg:px-8 lg:py-16"
>
  <h2
    id={`${sectionId}-heading`}
    class="mb-8 inline-block border-4 border-light-text bg-accent px-4 py-2 font-display text-h2 uppercase text-black shadow-brutal dark:border-dark-text dark:bg-accent dark:text-black"
  >
    Kontak
  </h2>

  <div
    class="flex flex-col gap-8 border-4 border-light-text bg-light-surface p-6 text-light-text shadow-brutal dark:border-dark-text dark:bg-dark-surface dark:text-dark-text sm:p-8"
  >
    <p class="max-w-xl font-sans text-base leading-relaxed text-light-text dark:text-dark-text">
      Tertarik bekerja sama atau punya pertanyaan? Hubungi saya lewat tautan di bawah.
    </p>

    {/* Tautan media profesional + kontak, dibuka aman di tab baru (Req 6.3, 6.4). */}
    {
      socialLinks.length > 0 && (
        <ul aria-label="Tautan media profesional" class="flex flex-wrap gap-3">
          {socialLinks.map((link) => {
            const key = link.label.toLowerCase();
            const isGithub = key.includes('github');
            const isWa = key.includes('whatsapp') || key.includes('wa.me');
            const isMail = key.includes('email') || key.includes('mail');
            return (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={link.label}
                  class="inline-flex items-center gap-2 border-4 border-light-text bg-light-surface px-5 py-3 font-display text-sm uppercase tracking-wider text-light-text shadow-brutal-sm transition-transform duration-150 ease-out hover:-translate-x-1 hover:-translate-y-1 hover:bg-accent hover:text-black focus:outline-none focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-2 focus-visible:outline-light-text dark:border-dark-text dark:bg-dark-surface dark:text-dark-text dark:hover:bg-accent dark:hover:text-black dark:focus-visible:outline-dark-text"
                >
                  {isGithub ? (
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.3-.5-1.5.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" />
                    </svg>
                  ) : isWa ? (
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.984-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
                    </svg>
                  ) : isMail ? (
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0-8 5L4 6h16zm0 12H4V8l8 5 8-5v10z" />
                    </svg>
                  ) : (
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" />
                    </svg>
                  )}
                  <span>{link.label}</span>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</section>

{/* Footer neobrutalism: copyright + tautan sosial. */}
<footer class="border-t-4 border-light-text bg-light-surface dark:border-dark-text dark:bg-dark-surface">
  <div
    class="mx-auto flex w-full max-w-content flex-col items-center justify-between gap-4 px-4 py-8 sm:flex-row sm:px-6 lg:px-8"
  >
    <p class="font-display text-sm uppercase tracking-wider text-light-text dark:text-dark-text">
      © {year} - {ownerName}
    </p>

    {
      socialLinks.length > 0 && (
        <ul aria-label="Tautan media profesional" class="flex gap-3">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center border-2 border-light-text px-3 py-1 font-display text-xs uppercase tracking-wide text-light-text transition-colors hover:bg-accent hover:text-black focus:outline-none focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-2 focus-visible:outline-light-text dark:border-dark-text dark:text-dark-text dark:hover:bg-accent dark:hover:text-black dark:focus-visible:outline-dark-text"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</footer>
