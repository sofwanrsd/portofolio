---
// Halaman 404 kustom (Req 8.2).
//
// Astro membangun berkas ini menjadi `404.html` pada Build_Statis. Apache
// menyajikannya via `ErrorDocument 404 /404.html` sehingga permintaan ke URL
// tanpa berkas yang sesuai memperoleh status 404 beserta indikasi bahwa sumber
// daya tidak ditemukan, plus tautan kembali ke halaman utama.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Halaman Tidak Ditemukan">
  <main class="mx-auto flex min-h-screen w-full max-w-content flex-col items-center justify-center px-4 py-16 text-center">
    <p class="text-6xl font-bold text-light-primary dark:text-dark-primary">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-light-text dark:text-dark-text">
      Halaman tidak ditemukan
    </h1>
    <p class="mt-2 max-w-prose text-light-text-muted dark:text-dark-text-muted">
      Maaf, halaman yang Anda cari tidak tersedia atau mungkin telah dipindahkan.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center justify-center rounded-md bg-light-primary px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-light-primary focus-visible:ring-offset-2 focus-visible:ring-offset-light-background dark:bg-dark-primary dark:text-dark-background dark:focus-visible:ring-dark-primary dark:focus-visible:ring-offset-dark-background"
    >
      Kembali ke beranda
    </a>
  </main>
</BaseLayout>
